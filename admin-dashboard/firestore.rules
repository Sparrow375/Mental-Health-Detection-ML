rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection: each user can only access their own document and subcollections
    match /users/{userId} {
      // A user can read/write their own profile doc
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // All subcollections (daily_features, results, baseline, location_data)
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Admin dashboard: any authenticated user can read all user documents
    // (your admin web app is Firebase-authenticated, so this covers the dashboard)
    match /users/{userId} {
      allow read: if request.auth != null;
      match /{subcollection}/{docId} {
        allow read: if request.auth != null;
      }
    }
  }
}