rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users Collection
    match /users/{userId} {
      // Only the authenticated user can access their own document
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Allow access to all subcollections (like profil, baseline, daily_data, results)
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Note: Admin dashboard access will bypass these rules if using Firebase Admin SDK 
    // or you can add custom claims for admin.
  }
}
  