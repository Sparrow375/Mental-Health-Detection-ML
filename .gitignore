# Git ignore for Mental Health Detection repo
.venv/
.agent/
.idea/
.gradle/
build/
local.properties
/MHealth - Copy/.gradle/
/MHealth - Copy/build/
/MHealth - Copy/local.properties
/MHealth - Copy/.idea/
*.class

# Python bytecode (should never be committed)
__pycache__/
*.py[cod]
*.pyc
*.pyo
 
# Ignore large ML weights
*.safetensors
*.pt
*.bin
*.h5
 
# Ignore large dataset CSVs
*.csv

# AI Assistant config and logs
.claude/
.gemini/
.cursor/
